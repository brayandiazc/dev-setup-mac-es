.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# ── Editores / IDE ────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~

# ── Temporales / logs ─────────────────────────────────────────────────────
*.log
tmp/
.cache/
